# Options_Trading .env.example
# Copy to .env and fill in. .env is gitignored.

# ---------- Data sources ----------

# FinMind API (600 calls/hr per token, IP-bound to 61.66.150.16)
# See: https://finmindtrade.com/
FINMIND_TOKEN=

# ---------- Market constants (override defaults in config/constants.py) ----------

# Annualised risk-free rate, decimal (e.g. 0.015 = 1.5%)
RISK_FREE_RATE=0.015

# ---------- Phase 2: Shioaji (Sinopac) broker — uncomment when integrating ----------

# SHIOAJI_API_KEY=
# SHIOAJI_SECRET=
# SHIOAJI_CA_PATH=
# SHIOAJI_CA_PASSWD=
# SHIOAJI_SIMULATION=true
